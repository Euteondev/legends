externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8090
externalPort = 3003

[[ports]]
localPort = 21698
externalPort = 80

[userenv]

[userenv.shared]
VITE_FIREBASE_API_KEY = "AIzaSyBZZOV_nlyKYqOry10kVHraRyq9bSz8AaE"
BASE_PATH = "/"
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd album && pnpm --filter @workspace/financas-legends run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd album && PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080
